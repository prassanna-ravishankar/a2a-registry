---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AgentPageClient from '@/components/AgentPageClient.jsx';
import { safeExternalUrl } from '@/lib/utils';

export const prerender = true;

export async function getStaticPaths() {
  const envBase = import.meta.env.PUBLIC_API_URL;
  // Default to `<site>/api` so self-hosters with a custom `site:` in
  // astro.config.mjs hit their own backend without needing PUBLIC_API_URL set.
  const siteFallback = `${(import.meta.env.SITE || 'https://a2aregistry.org').replace(/\/+$/, '')}/api`;
  const base = (envBase && /^https?:\/\//.test(envBase) ? envBase : siteFallback).replace(/\/+$/, '');
  const pageSize = 200;
  const maxAgents = Number(import.meta.env.MAX_AGENT_PAGES) || 10000;
  const agents = [];
  const allowEmpty = import.meta.env.ALLOW_EMPTY_AGENT_BUILD === '1';

  const fetchTimeoutMs = 30000;

  for (let offset = 0; offset < maxAgents; offset += pageSize) {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), fetchTimeoutMs);
    let data;
    try {
      const res = await fetch(
        `${base}/agents?healthy=true&limit=${pageSize}&offset=${offset}`,
        { signal: controller.signal },
      );
      if (!res.ok) {
        throw new Error(`[getStaticPaths] /agents returned ${res.status} at offset ${offset} from ${base}`);
      }
      data = await res.json();
    } finally {
      clearTimeout(timer);
    }
    const batch = data.agents || [];
    agents.push(...batch);
    if (batch.length < pageSize) break;
    if (data.total && agents.length >= data.total) break;
  }

  if (agents.length >= maxAgents) {
    console.warn(`[getStaticPaths] hit safety cap of ${maxAgents} agents; pagination may have stalled`);
  }

  if (agents.length === 0 && !allowEmpty) {
    throw new Error(`[getStaticPaths] fetched zero agents from ${base}. Set ALLOW_EMPTY_AGENT_BUILD=1 to override (e.g. in local dev without a live API).`);
  }

  return agents
    .filter((a) => a && a.id)
    .map((agent) => ({
      params: { slug: agent.id },
      props: { agent },
    }));
}

const { agent } = Astro.props;

const provider = agent.author || agent.provider?.organization || 'Unknown';
const title = `${agent.name} - A2A Protocol Agent | ${provider}`;

// Strip common inline Markdown so agents with **bold** / [link](url) /
// `code` don't show raw syntax in search-engine snippets.
const stripMarkdown = (s) => String(s ?? '')
  .replace(/<[^>]*>/g, '')                   // raw HTML tags
  .replace(/!?\[([^\]]*)\]\([^)]*\)/g, '$1') // images/links → alt/label
  .replace(/```[\s\S]*?```/g, '')            // fenced code blocks
  .replace(/`([^`]+)`/g, '$1')               // inline code
  .replace(/(\*\*|__)(.*?)\1/g, '$2')        // bold
  .replace(/(\*|_)(.*?)\1/g, '$2')           // italic
  .replace(/~~(.*?)~~/g, '$1')               // strikethrough
  .replace(/^#{1,6}\s+/gm, '')               // headings
  .replace(/\s+/g, ' ')
  .trim();

const shortDesc = stripMarkdown(agent.description).slice(0, 160);
const description = shortDesc || `${agent.name} is an A2A Protocol compliant agent available on A2A Registry.`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://a2aregistry.org').toString();
const siteRoot = (Astro.site ?? new URL('https://a2aregistry.org')).toString();

const topTags = Array.from(new Set((agent.skills || []).flatMap((s) => s.tags || []))).slice(0, 8);

const homepageUrl = safeExternalUrl(agent.homepage) || safeExternalUrl(agent.provider?.url) || safeExternalUrl(agent.documentationUrl) || safeExternalUrl(agent.url);

// JSON.stringify handles quotes, backslashes, and control chars — all of
// which are valid Python escape sequences too. Also escape backticks since
// the result is interpolated into a JS template literal just below.
const pyEscape = (s) => JSON.stringify(String(s ?? '')).slice(1, -1).replace(/`/g, '\\`');
const agentIdPy = pyEscape(agent.id);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: agent.name,
    description: agent.description,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    url: canonical,
    ...(homepageUrl ? { sameAs: [homepageUrl] } : {}),
    author: {
      '@type': 'Organization',
      name: provider,
      ...(safeExternalUrl(agent.provider?.url) ? { url: agent.provider.url } : {}),
    },
    ...(agent.version ? { softwareVersion: agent.version } : {}),
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    ...(topTags.length ? { keywords: topTags.join(', ') } : {}),
    isPartOf: {
      '@type': 'WebSite',
      name: 'A2A Registry',
      url: siteRoot,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'A2A Registry', item: siteRoot },
      { '@type': 'ListItem', position: 2, name: 'Agents', item: siteRoot },
      { '@type': 'ListItem', position: 3, name: agent.name, item: canonical },
    ],
  },
];
---
<BaseLayout
  title={title}
  description={description}
  ogType="article"
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    {topTags.length > 0 && <meta name="keywords" content={`${topTags.join(', ')}, A2A Protocol, AI agent`} />}
  </Fragment>

  <article class="min-h-screen bg-black text-zinc-200 font-mono">
    <header class="sticky top-0 z-40 border-b border-zinc-800 bg-zinc-950/95 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center gap-4 px-4 py-3 md:px-6">
        <a href="/" class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-zinc-400 hover:text-emerald-300">
          ← Back to registry
        </a>
        <span class="text-zinc-700">/</span>
        <h1 class="truncate font-mono text-sm font-semibold tracking-wider text-zinc-100">{agent.name}</h1>
      </div>
    </header>

    <div class="mx-auto max-w-5xl px-4 py-8 md:px-6 md:py-12">
      <nav aria-label="Breadcrumb" class="mb-6 text-[11px] uppercase tracking-[0.22em] text-zinc-500">
        <a href="/" class="hover:text-emerald-300">A2A Registry</a>
        <span class="mx-2 text-zinc-700">›</span>
        <a href="/" class="hover:text-emerald-300">Agents</a>
        <span class="mx-2 text-zinc-700">›</span>
        <span class="text-zinc-300">{agent.name}</span>
      </nav>

      <section class="mb-8 border border-zinc-800 bg-zinc-950/60 p-6">
        <div class="flex flex-wrap items-center gap-2">
          <span class={`inline-flex border px-2 py-1 font-mono text-[10px] uppercase tracking-[0.18em] ${
            agent.conformance === false
              ? 'border-amber-500/30 bg-amber-500/10 text-amber-300'
              : 'border-emerald-500/30 bg-emerald-500/10 text-emerald-300'
          }`}>
            {agent.conformance === false ? 'Non-standard' : 'A2A conformant'}
          </span>
          {agent.capabilities?.streaming && (
            <span class="inline-flex border border-cyan-500/30 bg-cyan-500/10 px-2 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-cyan-300">
              Streaming
            </span>
          )}
          {agent.protocolVersion && (
            <span class="inline-flex border border-zinc-700 bg-zinc-900 px-2 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-zinc-300">
              A2A v{agent.protocolVersion}
            </span>
          )}
        </div>

        <h2 class="mt-4 font-mono text-2xl font-semibold text-zinc-100">{agent.name}</h2>
        <p class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-zinc-500">
          {agent.version && <><span>v{agent.version}</span><span class="text-zinc-700">•</span></>}
          <span>{provider}</span>
          {agent.license && <><span class="text-zinc-700">•</span><span>{agent.license}</span></>}
        </p>

        <p class="mt-5 max-w-3xl text-sm leading-7 text-zinc-300">{agent.description}</p>

        {homepageUrl && (
          <p class="mt-5">
            <a
              href={homepageUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-zinc-100 bg-zinc-100 px-4 py-2 font-mono text-xs font-bold uppercase tracking-[0.18em] text-black hover:bg-white"
            >
              Launch agent website ↗
            </a>
          </p>
        )}
      </section>

      {agent.skills && agent.skills.length > 0 && (
        <section class="mb-8 border border-zinc-800 bg-zinc-950/60 p-6">
          <h3 class="font-mono text-[11px] uppercase tracking-[0.28em] text-zinc-500">Skills</h3>
          <ul class="mt-4 space-y-4">
            {agent.skills.map((skill) => (
              <li class="border border-zinc-800/60 bg-black/40 p-4">
                <p class="font-mono text-sm font-semibold text-zinc-100">{skill.name}</p>
                {skill.description && <p class="mt-1 text-xs leading-6 text-zinc-400">{skill.description}</p>}
                {skill.tags && skill.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {skill.tags.map((tag) => (
                      <span class="border border-zinc-800 bg-zinc-900 px-2 py-1 text-[11px] text-zinc-400">{tag}</span>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="mb-8 border border-zinc-800 bg-zinc-950/60 p-6">
        <h3 class="font-mono text-[11px] uppercase tracking-[0.28em] text-zinc-500">Integration</h3>
        <pre class="mt-3 overflow-x-auto border border-zinc-800 bg-black p-3 font-mono text-[11px] text-zinc-400">{`import asyncio
from a2a_registry import AsyncRegistry

async def main():
    async with AsyncRegistry() as registry:
        agent = await registry.get_by_id("${agentIdPy}")
        client = await agent.async_connect()
        print(f"Connected to {agent.name}")

asyncio.run(main())`}</pre>
      </section>

      <AgentPageClient client:visible agent={agent} />
    </div>
  </article>
</BaseLayout>
